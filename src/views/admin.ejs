<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#ff4d6d">
    <link rel="icon" href="/icons/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png">
</head>

<body class="retro-page admin-page">
    <div class="stars"></div>
    <main class="dashboard">
        <header class="panel header-panel">
            <img src="/icons/logo.webp" alt="FICE" class="site-logo">
            <div>
                <p class="label">PAINEL ADMIN</p>
                <h1>
                    FICE · 2026
                </h1>
            </div>
            <!-- <a class="btn secondary" href="/">Voltar ao início</a> -->
        </header>

        <% if (typeof error !=='undefined' && error) { %>
            <div class="message error">
                <%= error %>
            </div>
            <% } %>

                <section class="stats-grid">
                    <article class="panel stat-card">
                        <h2>
                            <%= stats.totalVisitors %>
                        </h2>
                        <p>Visitantes registrados</p>
                    </article>
                    <article class="panel stat-card">
                        <h2>
                            <%= stats.redeemed %>
                        </h2>
                        <p>Recompensas liberadas</p>
                    </article>
                    <article class="panel stat-card">
                        <h2>
                            <%= stats.pending %>
                        </h2>
                        <p>Aguardando retirada</p>
                    </article>
                </section>
                <section class="panel list-panel">
                    <h3>Últimos registros</h3>

                    <ul class="recent-list">
                        <li class="list-header">
                            <span>ID</span>
                            <span>Evento</span>
                            <span>Status</span>
                            <span>Data/Hora</span>
                        </li>

                        <% recent.forEach(item=> { %>
                            <li>
                                <span>#<%= item.id %></span>
                                <span>
                                    <%= item.event_id %>
                                </span>
                                <span class="<%= item.reward_given ? 'ok' : 'warn' %>">
                                    <%= item.reward_given ? '✔' : '⏳' %>
                                </span>
                                <span>
                                    <%= new Date(item.captured_at).toLocaleString('pt-BR') %>
                                </span>
                            </li>
                            <% }) %>
                    </ul>
                </section>
    </main>

    <footer class="site-footer">
        <p>&copy; Desenvolvido pela Fábrica de Software - IFC Videira </p>
        <div class="footer-links">
            <a href="https://fabrica.videira.ifc.edu.br/" target="_blank" rel="noopener noreferrer"
                aria-label="Site da Fábrica de Software">
                <i class="fa-solid fa-globe"></i>
            </a>
            <a href="https://www.instagram.com/fsw.ifcvideira" target="_blank" rel="noopener noreferrer"
                aria-label="Instagram da Fábrica de Software">
                <i class="fa-brands fa-instagram"></i>
            </a>
        </div>
    </footer>
    <button id="pwaInstallBtn" class="btn pwa-install-button">Instalar app</button>
    <script src="/js/pwa.js" defer></script>
</body>

</html>