<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#ff4d6d">
    <link rel="icon" href="/icons/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png">
</head>

<body class="retro-page home-page">
    <div class="stars"></div>
    <main class="hero">
        <div class="hero-card">
            <img src="/icons/logo.webp" alt="FICE" class="site-logo">
            <p class="label">Feira de Iniciação Científica e Extensão</p>
            <h1>FICE · 2026</h1>
            <p class="subtitle">Visite nossos stands e receba recompensas!</p>
            <div class="actions">
                <a class="btn primary" href="/estande">Ir para o stand</a>
                <a class="btn secondary" href="/recompensa">Retirar recompensa</a>
                <a class="btn admin" href="/admin">Painel admin</a>
            </div>
        </div>
    </main>

    <footer class="site-footer">
        <p>&copy; Desenvolvido pela Fábrica de Software - IFC Videira </p>
        <div class="footer-links">
            <a href="https://fabrica.videira.ifc.edu.br/" target="_blank" rel="noopener noreferrer"
                aria-label="Site da Fábrica de Software"><i class="fa-solid fa-globe"></i></a>
            <a href="https://www.instagram.com/fsw.ifcvideira" target="_blank" rel="noopener noreferrer"
                aria-label="Instagram da Fábrica de Software"><i class="fa-brands fa-instagram"></i></a>
        </div>
    </footer>
    <button id="pwaInstallBtn" class="btn pwa-install-button">Instalar app</button>
    <script src="/js/pwa.js" defer></script>
</body>

</html>